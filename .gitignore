# Prerequisites
pico-sdk/
*.d

# CMake/build output. Keep the released UF2 artifact trackable.
build/*
!build/
!build/pikocore.uf2
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# Web dependencies and local caches. Keep web/dist trackable for the static site.
web/node_modules/
web/.vite/
# Duplicate of the released UF2 copied here by `make build`; the canonical
# artifact is build/pikocore.uf2 (see above).
web/public/pikocore.uf2

# audio2h generated output and sample assets (not source). The converted
# WAVs + manifest are produced by audio2h/main.go; samples/ holds the raw
# input WAVs; doth/audio2h.h is its generated header (unused by the build).
audio2h/samples/
audio2h/converted/
audio2h/converted10/
audio2h/converted24/
audio2h/files.json
doth/audio2h.h

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# macOS
.DS_Store
